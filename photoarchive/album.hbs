<!DOCTYPE html>
<html>

  <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, user-scalable=no" />
      <title>{{gallery.title}} - {{album.title}}</title>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/css/lightgallery-bundle.min.css" integrity="sha512-nUqPe0+ak577sKSMThGcKJauRI7ENhKC2FQAOOmdyCYSrUh0GnwLsZNYqwilpMmplN+3nO3zso8CWUgu33BDag==" crossorigin="anonymous" referrerpolicy="no-referrer" />
      <link rel="stylesheet" href="{{relative 'public/core.css'}}" />
      <link rel="stylesheet" href="{{relative 'public/theme.css'}}" />

      <link rel="icon" type="image/png" href="{{relative 'public/icon.png'}}">

      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/justifiedGallery/3.8.1/css/justifiedGallery.min.css" integrity="sha512-CRFv/YVJyElHXTiMgnhWKd2f04Hd/BUJkwcyqYmlpL1ugSYW23nNRazLk960mlz7dugTrETCGGjcsnspPOS6qA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

      <style>
        /* ── Shared toolbar button style ─────────────────────────── */
        .lg-exif-btn,
        .lg-slideshow-btn {
          width: 50px;
          height: 47px;
          cursor: pointer;
          color: rgb(153, 153, 153);
          background: none;
          border: none;
          padding: 0;
          transition: color 0.2s;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          font-size: 20px;
          font-weight: 300;
          line-height: 1;
        }
        .lg-exif-btn:hover,
        .lg-slideshow-btn:hover { color: #fff; }
        .lg-slideshow-btn.playing { color: #fff; }

        /* Toolbar flex order: zoom=10, slideshow=11, info=12, close=13 */
        .lg-toolbar .lg-zoom-in       { order: 10; }
        .lg-toolbar #lg-slideshow-btn { order: 11; }
        .lg-toolbar #lg-exif-btn      { order: 12; }
        .lg-toolbar .lg-close         { order: 13; }

        /* ── EXIF panel ───────────────────────────────────────────── */
        #lg-exif-panel {
          display: none;
          position: absolute;
          bottom: 80px;
          right: 16px;
          background: rgba(0, 0, 0, 0.75);
          color: #fff;
          border-radius: 8px;
          padding: 14px 18px;
          font-size: 13px;
          line-height: 1.8;
          z-index: 10000;
          min-width: 220px;
          backdrop-filter: blur(6px);
          pointer-events: none;
        }
        #lg-exif-panel.visible { display: block; }
        #lg-exif-panel table { border-collapse: collapse; width: 100%; }
        #lg-exif-panel td { padding: 1px 0; vertical-align: top; }
        #lg-exif-panel td:first-child {
          color: #aaa;
          padding-right: 12px;
          white-space: nowrap;
        }
        #lg-exif-panel .no-exif { color: #aaa; font-style: italic; }

        /* ── Ken Burns effect ─────────────────────────────────────── */
        @keyframes kenBurns {
          from { transform: scale(1.0);  }
          to   { transform: scale(1.1) translateY(4%); }
        }
        .lg-current .lg-image.kb-active {
          animation: kenBurns var(--kb-duration, 11s) ease-out forwards;
          transform-origin: center center;
        }

        /* ── Play button on thumbnail grid ───────────────────────── */
        #slideshow-launch {
          position: fixed;
          bottom: 32px;
          right: 32px;
          z-index: 1000;
          display: flex;
          align-items: center;
          gap: 10px;
          padding: 12px 24px;
          background: rgba(0, 0, 0, 0.7);
          color: #fff;
          border: 1px solid rgba(255,255,255,0.25);
          border-radius: 32px;
          font-size: 14px;
          font-family: inherit;
          cursor: pointer;
          backdrop-filter: blur(8px);
          transition: background 0.2s, border-color 0.2s;
          letter-spacing: 0.04em;
        }
        #slideshow-launch:hover {
          background: rgba(0,0,0,0.9);
          border-color: rgba(255,255,255,0.5);
        }
        #slideshow-launch .play-icon {
          font-size: 16px;
          line-height: 1;
        }
      </style>

  </head>

  <body>

    {{> content}}
    {{> video-loader}}

    <!-- EXIF panel -->
    <div id="lg-exif-panel"></div>

    <!-- Slideshow launch button on thumbnail grid -->
    <button id="slideshow-launch" title="Start slideshow">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg> Slideshow
    </button>

    <!-- jquery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <!-- LightGallery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/lightgallery.min.js" integrity="sha512-jEJ0OA9fwz5wUn6rVfGhAXiiCSGrjYCwtQRUwI/wRGEuWRZxrnxoeDoNc+Pnhx8qwKVHs2BRQrVR9RE6T4UHBg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/zoom/lg-zoom.min.js" integrity="sha512-BLW2Jrofiqm6m7JhkQDIh2olT0EBI58+hIL/AXWvo8gOXKmsNlU6myJyEkTy6rOAAZjn0032FRk8sl9RgXPYIQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightgallery/2.7.2/plugins/thumbnail/lg-thumbnail.min.js" integrity="sha512-VBbe8aA3uiK90EUKJnZ4iEs0lKXRhzaAXL8CIHWYReUwULzxkOSxlNixn41OLdX0R1KNP23/s76YPyeRhE6P+Q==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script type="text/javascript">

      var SLIDESHOW_DELAY = 10000; // 10 seconds between slides

      var lgInstance = lightGallery(document.getElementById('gallery'), {
        speed: 1200,
        loop: true,
        controls: true,
        counter: true,
        download: false,
        appendSubHtmlTo: ".lg-sub-html",
        licenseKey: "GNU GPL license v3",

        thumbnail: true,
        toggleThumb: true,
        animateThumb: true,
        allowMediaOverlap: false,
        enableThumbDrag: true,
        thumbWidth: 75,
        thumbHeight: "50px",

        plugins: [lgZoom, lgThumbnail]
      });

      // ── Slideshow state ──────────────────────────────────────────────────────

      var slideshowTimer = null;
      var slideshowPlaying = false;
      var slideshowBtn = null;

      function setThumbstrip(visible) {
        var thumbs = document.querySelector('.lg-thumb-outer');
        if (thumbs) thumbs.style.display = visible ? '' : 'none';
      }

      function startSlideshow() {
        if (slideshowTimer) return;
        slideshowPlaying = true;
        setThumbstrip(false);
        triggerKenBurns();
        slideshowTimer = setInterval(function() {
          lgInstance.goToNextSlide();
        }, SLIDESHOW_DELAY);
        if (slideshowBtn) {
          slideshowBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><rect x="5" y="3" width="4" height="18"/><rect x="15" y="3" width="4" height="18"/></svg>';
          slideshowBtn.classList.add('playing');
          slideshowBtn.title = 'Pause slideshow (Space)';
        }
      }

      function stopSlideshow() {
        if (slideshowTimer) {
          clearInterval(slideshowTimer);
          slideshowTimer = null;
        }
        slideshowPlaying = false;
        setThumbstrip(true);
        document.querySelectorAll('.lg-image').forEach(function(img) {
          img.classList.remove('kb-active');
        });
        if (slideshowBtn) {
          slideshowBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>';
          slideshowBtn.classList.remove('playing');
          slideshowBtn.title = 'Play slideshow (Space)';
        }
      }

      function toggleSlideshow() {
        if (slideshowPlaying) {
          stopSlideshow();
        } else {
          startSlideshow();
        }
      }

      // ── EXIF panel ───────────────────────────────────────────────────────────

      var exifPanelVisible = false;
      var exifPanel = document.getElementById('lg-exif-panel');

      function formatShutter(val) {
        if (!val) return null;
        if (typeof val === 'string' && val.indexOf('/') !== -1) {
          var parts = val.split('/');
          var num = parseFloat(parts[0]);
          var den = parseFloat(parts[1]);
          if (!isNaN(num) && !isNaN(den) && den !== 0) {
            var s = num / den;
            if (s >= 1) return Math.round(s) + 's';
            return '1/' + Math.round(1 / s) + 's';
          }
          return val;
        }
        var n = parseFloat(val);
        if (isNaN(n)) return val;
        if (n >= 1) return Math.round(n) + 's';
        return '1/' + Math.round(1 / n) + 's';
      }

      function formatAperture(val) {
        if (!val) return null;
        return 'f/' + parseFloat(val).toFixed(1).replace(/\.0$/, '');
      }

      function formatFocal(val) {
        if (!val) return null;
        return parseFloat(val).toFixed(0) + 'mm';
      }

      function updateExifPanel(index) {
        var items = document.querySelectorAll('#gallery > a');
        var el = items[index];
        if (!el) { exifPanel.innerHTML = ''; return; }
        var d = el.dataset;
        var make  = d.make  || '';
        var model = d.model || '';
        var camera = [make, model].filter(Boolean).join(' ') || null;
        if (make && model && model.toLowerCase().startsWith(make.toLowerCase())) {
          camera = model;
        }
        var rows = [
          ['Camera',       camera],
          ['Lens',         d.lens || d.lensmodel || null],
          ['Aperture',     formatAperture(d.fnumber)],
          ['Shutter',      formatShutter(d.exposuretime)],
          ['ISO',          d.isospeedratings ? 'ISO ' + d.isospeedratings : null],
          ['Focal Length', formatFocal(d.focallength)],
        ].filter(function(r) { return r[1]; });
        if (rows.length === 0) {
          exifPanel.innerHTML = '<span class="no-exif">No EXIF data</span>';
        } else {
          exifPanel.innerHTML = '<table>' + rows.map(function(r) {
            return '<tr><td>' + r[0] + '</td><td>' + r[1] + '</td></tr>';
          }).join('') + '</table>';
        }
      }

      function toggleExifPanel() {
        exifPanelVisible = !exifPanelVisible;
        exifPanel.classList.toggle('visible', exifPanelVisible);
      }

      // ── Inject toolbar buttons on open ───────────────────────────────────────

      document.getElementById('gallery').addEventListener('lgAfterOpen', function() {
        var lgOuter = document.querySelector('.lg-outer');
        if (lgOuter && !lgOuter.contains(exifPanel)) {
          lgOuter.appendChild(exifPanel);
        }

        var toolbar = document.querySelector('.lg-toolbar');
        var closeBtn = toolbar && toolbar.querySelector('.lg-close');

        // Slideshow button
        if (!document.getElementById('lg-slideshow-btn')) {
          slideshowBtn = document.createElement('button');
          slideshowBtn.id = 'lg-slideshow-btn';
          slideshowBtn.className = 'lg-slideshow-btn lg-icon';
          slideshowBtn.title = 'Play slideshow (Space)';
          slideshowBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>';
          slideshowBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            toggleSlideshow();
          });
          if (closeBtn) toolbar.insertBefore(slideshowBtn, closeBtn);
          else if (toolbar) toolbar.appendChild(slideshowBtn);
        } else {
          slideshowBtn = document.getElementById('lg-slideshow-btn');
        }

        // EXIF info button
        if (!document.getElementById('lg-exif-btn')) {
          var btn = document.createElement('button');
          btn.id = 'lg-exif-btn';
          btn.className = 'lg-exif-btn lg-icon';
          btn.title = 'Photo info';
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="8.5"/><line x1="12" y1="11" x2="12" y2="16"/></svg>';
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            toggleExifPanel();
          });
          if (closeBtn) toolbar.insertBefore(btn, closeBtn);
          else if (toolbar) toolbar.appendChild(btn);
        }

        // If launched from grid play button, start immediately
        if (window._startSlideshowOnOpen) {
          window._startSlideshowOnOpen = false;
          startSlideshow();
        }

        updateExifPanel(0);
      });

      // Trigger Ken Burns on the current slide image
      function triggerKenBurns() {
        // Remove from all slides first to reset animation
        document.querySelectorAll('.lg-image').forEach(function(img) {
          img.classList.remove('kb-active');
        });
        // Add to current slide image after a brief delay to ensure reset
        setTimeout(function() {
          var current = document.querySelector('.lg-current .lg-image');
          if (current) {
            current.style.setProperty('--kb-duration', (SLIDESHOW_DELAY / 1000 + 1) + 's');
            current.classList.add('kb-active');
          }
        }, 50);
      }

      // Update EXIF on slide change; reset slideshow timer so each photo gets full delay
      document.getElementById('gallery').addEventListener('lgAfterSlide', function(e) {
        updateExifPanel(e.detail.index);
        if (slideshowPlaying) {
          triggerKenBurns();
          clearInterval(slideshowTimer);
          slideshowTimer = setInterval(function() {
            lgInstance.goToNextSlide();
          }, SLIDESHOW_DELAY);
        }
      });

      // Stop slideshow and hide panel when lightgallery closes
      document.getElementById('gallery').addEventListener('lgBeforeClose', function() {
        stopSlideshow();
        exifPanelVisible = false;
        exifPanel.classList.remove('visible');
      });

      // Spacebar = play/pause; also stop slideshow if user manually navigates
      document.addEventListener('keydown', function(e) {
        if (!document.querySelector('.lg-outer')) return; // only when lg is open
        if (e.code === 'Space') {
          e.preventDefault();
          toggleSlideshow();
        }
      });

      // Manual prev/next stops the slideshow so user can browse freely
      document.getElementById('gallery').addEventListener('lgBeforeSlide', function(e) {
        // Only stop if the slide change wasn't triggered by our timer
        // We detect this by checking if it's a user gesture (detail.fromTouch or controls)
        if (slideshowPlaying && e.detail && e.detail.fromTouch) {
          stopSlideshow();
        }
      });

      // ── Grid play button ─────────────────────────────────────────────────────

      document.getElementById('slideshow-launch').addEventListener('click', function() {
        window._startSlideshowOnOpen = true;
        // Open the first image in the gallery
        var firstItem = document.querySelector('#gallery > a');
        if (firstItem) firstItem.click();
      });

    </script>

    <!-- Justified gallery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/justifiedGallery/3.8.1/js/jquery.justifiedGallery.min.js" integrity="sha512-8dQZtymfQeDiZ4bBCFhrKZhDcZir15MqnEDBRiR6ReIVHLcdnCyJrhPIS0QifLGuMkFZsw9QMNeD9JtiLwieTQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>
      $("#gallery").justifiedGallery({
        rowHeight: 240,
        maxRowHeight: "200%",
        lastRow: 'nojustify',
        margins: 32,
        captions: false,
        border: 0,
        cssAnimation: true,
      });
    </script>

  </body>
</html>
